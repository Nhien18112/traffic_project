# ==========================================
# FILE MẪU BIẾN MÔI TRƯỜNG CHO TOÀN BỘ PROJECT
# Hướng dẫn cho team: 
# 1. Copy file này và đổi tên thành .env (bắt buộc phải có dấu chấm ở đầu)
# 2. Điền các API Key thật của bạn vào các ô bên dưới
# 3. Liên hệ Data Engineer để lấy mật khẩu Database Cloud (Neon)
# ==========================================

# --- 1. API KEYS (Thu thập dữ liệu) ---
# Đăng ký tại: developer.tomtom.com
TOMTOM_API_KEY=your_tomtom_api_key_here

# Đăng ký tại: openweathermap.org
WEATHER_API_KEY=your_openweather_api_key_here


# --- 2. DATABASE CONFIG (PostgreSQL Cục bộ cho Airflow) ---
# Lưu ý: Giữ nguyên các thông số này để Airflow chạy trong Docker
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow


# --- 3. KAFKA CONFIG ---
KAFKA_BROKER=kafka:9092


# --- 4. CLOUD DATA WAREHOUSE (NEON.TECH) ---
# User được cấp quyền truy cập Database trên mây
NEON_USER=neondb_owner

# MẬT KHẨU: Hãy hỏi Data Engineer để lấy mật khẩu điền vào đây
NEON_PASSWORD=nhap_mat_khau_duoc_cung_cap_vao_day

# Dành cho Data Engineer (Chạy Spark Streaming)
NEON_JDBC_URL=jdbc:postgresql://ep-proud-cloud-a1f7lzka-pooler.ap-southeast-1.aws.neon.tech:5432/neondb?sslmode=require

# Dành cho Backend (FastAPI) & Machine Learning (Pandas)
# Nhớ thay chữ NHAP_MAT_KHAU_VAO_DAY bằng mật khẩu thật
NEON_POSTGRES_URL=postgresql://neondb_owner:NHAP_MAT_KHAU_VAO_DAY@ep-proud-cloud-a1f7lzka-pooler.ap-southeast-1.aws.neon.tech:5432/neondb?sslmode=require