# ==========================================
# FILE MẪU BIẾN MÔI TRƯỜNG CHO TOÀN BỘ PROJECT
# Hướng dẫn cho team: 
# 1. Copy file này và đổi tên thành .env 
# 2. Điền các API Key thật của bạn vào các ô bên dưới
# ==========================================

# --- 1. API KEYS (Thu thập dữ liệu) ---
# Đăng ký tại: developer.tomtom.com
TOMTOM_API_KEY=your_tomtom_api_key_here

# Đăng ký tại: openweathermap.org
OPENWEATHER_API_KEY=your_openweather_api_key_here


# --- 2. DATABASE CONFIG (PostgreSQL) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=your_database_password_here
POSTGRES_DB=airflow


# --- 3. KAFKA CONFIG ---
KAFKA_BROKER=kafka:9092